{
  "name": "@dgalvarestec/alex",
  "version": "1.0.3",
  "description": "A.L.E.X code review microservice powered by Google ADK multi-agent reasoning",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dgalvares/A.L.E.X.-Advanced-Logic-Evaluation-X-ray-.git"
  },
  "bin": {
    "alex": "./dist/cli.js"
  },
  "main": "./dist/agent.js",
  "types": "./dist/agent.d.ts",
  "exports": {
    ".": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test tests/unit/*.test.mjs",
    "prepack": "npm run build",
    "start:api": "node dist/server.js"
  },
  "engines": {
    "node": ">=24.13.0",
    "npm": ">=11.8.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai",
    "code-review",
    "github-actions",
    "gemini",
    "google-adk",
    "multi-agent"
  ],
  "author": "DgAlvaresTEC",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@google/adk": "^1.0.0",
    "@types/express-rate-limit": "^5.1.3",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "ora": "^9.4.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@google/adk-devtools": "^1.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
