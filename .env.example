# Configurações de API do Google ADK
# Obtenha sua chave em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="SUA_CHAVE_AQUI"

# Modelo padrão usado pela CLI e pela API quando a requisição não define outro.
ALEX_MODEL="gemini-2.5-pro"

# Obrigatório para usar a API REST. A CLI não exige este token.
API_BEARER_TOKEN="troque_este_token"

# Para deploy em Cloud Run/Kubernetes, informe o CIDR confiável da rede interna.
# Em desenvolvimento local, o padrão do código é "loopback".
# TRUSTED_PROXY_CIDR="10.0.0.0/8"

# Se estiver usando Vertex AI (Google Cloud):
# GOOGLE_GENAI_USE_VERTEXAI=1
# GOOGLE_CLOUD_PROJECT="seu-projeto-id"
# GOOGLE_CLOUD_LOCATION="us-central1"
# GOOGLE_APPLICATION_CREDENTIALS="path/to/credentials.json"
