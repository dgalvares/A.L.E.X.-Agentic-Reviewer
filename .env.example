# Configurações de API do Google ADK
# Obtenha sua chave em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="SUA_CHAVE_AQUI"

# Modelo padrão usado pela CLI e pela API quando a requisição não define outro.
ALEX_MODEL="gemini-2.5-pro"

# Obrigatório para usar a API REST. A CLI não exige este token.
API_BEARER_TOKEN="troque_este_token"

# Para deploy em Cloud Run/Kubernetes, informe o CIDR confiável da rede interna.
# Em desenvolvimento local, o padrão do código é "loopback".
# TRUSTED_PROXY_CIDR="10.0.0.0/8"

# Se estiver usando Vertex AI (Google Cloud):
# GOOGLE_GENAI_USE_VERTEXAI=1
# GOOGLE_CLOUD_PROJECT="seu-projeto-id"
# GOOGLE_CLOUD_LOCATION="us-central1"
# GOOGLE_APPLICATION_CREDENTIALS="path/to/credentials.json"

# --- Overrides de Modelo por Agente ---
# Você pode definir um modelo específico para cada agente.
# Se não for definido, eles usarão ALEX_MODEL (Padrão: gemini-2.5-pro).
#
# AVISO: Usar "gemini-2.0-flash" para muitos agentes simultaneamente pode causar 
# erros de Rate Limit (HTTP 429). Recomenda-se manter o Architect em "pro".
#
# ALEX_MODEL_SECURITY_AUDITOR="gemini-2.0-flash"
# ALEX_MODEL_CLEAN_CODER="gemini-2.0-flash"
# ALEX_MODEL_SRE_AGENT="gemini-2.0-flash"
# ...

# --- Overrides para Agentes Internos/Revisores ---
# Recomenda-se manter o Architect em modelos "pro" para melhor consolidação.
# ALEX_MODEL_ARCHITECT_CONSOLIDATOR="gemini-2.5-pro"
# ALEX_MODEL_SECURITY_REVIEWER="gemini-2.0-flash"
# ALEX_MODEL_PERFORMANCE_REVIEWER="gemini-2.0-flash"
